<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <activity
            android:name="org.aurorasms.app.appearance.ThemeStudioTestActivity"
            android:exported="false" />
        <activity
            android:name="org.aurorasms.app.appearance.ScopedAppearanceTestActivity"
            android:exported="false" />
        <activity
            android:name="org.aurorasms.app.AuroraSmsRootTestActivity"
            android:exported="false" />
        <activity
            android:name="org.aurorasms.app.AuroraComposeTestActivity"
            android:exported="false" />

        <!-- Read-only shell probe used by disposable-emulator owner journeys. -->
        <provider
            android:name="org.aurorasms.app.debug.DebugSmsSnapshotProvider"
            android:authorities="org.aurorasms.app.debug.sms_snapshot"
            android:exported="true"
            android:permission="android.permission.DUMP" />

        <!-- Debug is not a performance deliverable and exposes no profile control surface. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            tools:node="remove"
            tools:ignore="MissingClass" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            tools:node="remove"
            tools:ignore="MissingClass" />
    </application>
</manifest>
