<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <activity
            android:name="org.aurorasms.app.appearance.ThemeStudioTestActivity"
            android:exported="false" />
        <activity
            android:name="org.aurorasms.app.appearance.ScopedAppearanceTestActivity"
            android:exported="false" />

        <!-- Debug is not a performance deliverable and exposes no profile control surface. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            tools:node="remove"
            tools:ignore="MissingClass" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            tools:node="remove"
            tools:ignore="MissingClass" />
    </application>
</manifest>
